{
  "name": "@arcsyn/react",
  "version": "0.1.0",
  "description": "React adapter for the ArcSyn Design System.",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/components/button/index.d.ts",
      "import": "./dist/components/button/index.js"
    },
    "./styles.css": "@arcsyn/styles"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@arcsyn/icons": "workspace:*",
    "@arcsyn/styles": "workspace:*",
    "@arcsyn/tokens": "workspace:*",
    "@base-ui/react": "1.6.0",
    "sonner": "2.0.7"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.build.json --noEmit"
  }
}
